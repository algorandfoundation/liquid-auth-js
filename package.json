{
  "name": "@algorandfoundation/liquid-client",
  "version": "1.0.0-canary.3",
  "description": "Connect to a Liquid Auth service",
  "main": "./lib/cjs/index.cjs",
  "module": "./lib/esm/index.js",
  "types": "./lib/types/index.d.ts",
  "browser": "./lib/esm/index.js",
  "type": "module",
  "publishConfig": {
    "provenance": true,
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./lib/types/index.d.ts",
      "import": "./lib/esm/index.js",
      "require": "./lib/cjs/index.cjs"
    },
    "./attestation": {
      "types": "./lib/types/attestation.d.ts",
      "import": "./lib/esm/attestation.js",
      "require": "./lib/cjs/attestation.cjs"
    },
    "./assertion": {
      "types": "./lib/types/assertion.d.ts",
      "import": "./lib/esm/assertion.js",
      "require": "./lib/cjs/assertion.cjs"
    },
    "./assertion/fetch": {
      "types": "./lib/types/assertion.fetch.d.ts",
      "import": "./lib/esm/assertion.fetch.js",
      "require": "./lib/cjs/assertion.fetch.cjs"
    },
    "./signal": {
      "types": "./lib/types/signal.d.ts",
      "import": "./lib/esm/signal.js",
      "require": "./lib/cjs/signal.cjs"
    },
    "./errors": {
      "types": "./lib/types/errors.d.ts",
      "import": "./lib/esm/errors.js",
      "require": "./lib/cjs/errors.cjs"
    },
    "./encoding": {
      "types": "./lib/types/encoding.d.ts",
      "import": "./lib/esm/encoding.js",
      "require": "./lib/cjs/encoding.cjs"
    }
  },
  "files": [
    "lib"
  ],
  "scripts": {
    "dev": "wait-on -t 3s http://localhost:3000/auth/session && vite",
    "build": "npm run build:esm && npm run build:cjs",
    "build:esm": "vite build",
    "build:cjs": "LIQUID_AUTH_JS_BUILD_FORMAT=cjs vite build",
    "build:docs": "typedoc --plugin typedoc-plugin-markdown --out docs src src/client",
    "lint": "eslint --fix src",
    "bench": "vitest bench",
    "test": "vitest",
    "test:browser": "vitest --browser.headless",
    "test:cov": "vitest run --coverage",
    "typedoc": "typedoc --tsconfig tsconfig.app.json",
    "typedoc:watch": "typedoc --watch --tsconfig tsconfig.app.json",
    "typedoc:serve": "nodemon --watch docs --exec \"http-server ./docs\"",
    "typedoc-dev": "concurrently \"npm:typedoc:*\"",
    "release": "semantic-release",
    "prepare": "npm run build"
  },
  "author": "Algorand Foundation",
  "license": "Apache-2.0",
  "devDependencies": {
    "@codecov/vite-plugin": "^1.9.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^12.0.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^10.0.3",
    "@semantic-release/npm": "^13.1.3",
    "@semantic-release/release-notes-generator": "^13.0.0",
    "@types/qrcode": "^1.5.5",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.8.0",
    "@typescript-eslint/parser": "^7.8.0",
    "@vitest/browser": "^3.0.8",
    "@vitest/coverage-v8": "^3.0.8",
    "concurrently": "^9.1.2",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-tsdoc": "^0.2.17",
    "glob": "^11.0.1",
    "http-server": "^14.1.1",
    "nodemon": "^3.1.9",
    "playwright": "^1.51.0",
    "semantic-release": "^25.0.2",
    "socket.io-mock-ts": "^1.0.2",
    "typedoc": "^0.27.9",
    "typedoc-plugin-markdown": "4.4.2",
    "typescript": "^5.8.2",
    "vite": "^6.2.2",
    "vite-bundle-analyzer": "^0.18.0",
    "vite-plugin-dts": "^4.5.3",
    "vitest": "^3.0.8",
    "wait-on": "^8.0.3"
  },
  "dependencies": {
    "canvas": "^2.11.2",
    "eventemitter3": "^5.0.1",
    "qr-code-styling": "^1.9.1",
    "socket.io-client": "^4.7.5",
    "tweetnacl": "^1.0.3",
    "uuid": "^10.0.0"
  },
  "release": {
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/changelog",
      "@semantic-release/npm",
      [
        "@semantic-release/git",
        {
          "assets": [
            "CHANGELOG.md",
            "package.json"
          ],
          "message": "chore(release): [skip ci] Liquid Client \n\n${nextRelease.notes}"
        }
      ],
      [
        "@semantic-release/github",
        {
          "successComment": false
        }
      ]
    ],
    "branches": [
      "release/*",
      {
        "name": "main",
        "prerelease": "canary"
      }
    ]
  }
}