{
  "name": "@algorandfoundation/liquid-client",
  "version": "1.0.0-canary.3",
  "description": "Connect to a Liquid Auth service",
  "main": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "browser": "./liquid-client.esm.js",
  "type": "module",
  "publishConfig": {
    "provenance": true,
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "default": "./lib/index.js"
    },
    "./attestation": {
      "types": "./lib/attestation.d.ts",
      "default": "./lib/attestation.js"
    },
    "./assertion": {
      "types": "./lib/assertion.d.ts",
      "default": "./lib/assertion.js"
    },
    "./assertion/fetch": {
      "types": "./lib/assertion.fetch.d.ts",
      "default": "./lib/assertion.fetch.js"
    },
    "./signal": {
      "types": "./lib/signal.d.ts",
      "default": "./lib/signal.js"
    },
    "./errors": {
      "types": "./lib/errors.d.ts",
      "default": "./lib/errors.js"
    },
    "./encoding": {
      "types": "./lib/encoding.d.ts",
      "default": "./lib/encoding.js"
    }
  },
  "scripts": {
    "dev": "wait-on -t 3s http://localhost:3000/auth/session && vite",
    "build": "vite build",
    "build:docs": "typedoc --plugin typedoc-plugin-markdown --out docs src src/client",
    "lint": "eslint --fix src",
    "bench": "vitest bench",
    "test": "vitest",
    "test:browser": "vitest --browser.headless",
    "test:cov": "vitest run --coverage",
    "typedoc": "typedoc --tsconfig tsconfig.app.json",
    "typedoc:watch": "typedoc --watch --tsconfig tsconfig.app.json",
    "typedoc:serve": "nodemon --watch docs --exec \"http-server ./docs\"",
    "typedoc-dev": "concurrently \"npm:typedoc:*\"",
    "release": "semantic-release"
  },
  "author": "Algorand Foundation",
  "license": "Apache-2.0",
  "devDependencies": {
    "@codecov/vite-plugin": "1.9.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.2",
    "@semantic-release/npm": "^13.1.3",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/node": "^25.0.3",
    "@types/qrcode": "1.5.6",
    "@types/unist": "^3.0.3",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.50.1",
    "@typescript-eslint/parser": "^8.50.1",
    "@vitest/browser": "^4.0.16",
    "@vitest/coverage-v8": "^4.0.16",
    "concurrently": "^9.1.2",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-tsdoc": "^0.5.0",
    "glob": "^13.0.0",
    "http-server": "^14.1.1",
    "jest-mock-extended": "^4.0.0",
    "nodemon": "^3.1.9",
    "playwright": "^1.51.0",
    "semantic-release": "^25.0.2",
    "socket.io-mock-ts": "^1.0.2",
    "typedoc": "^0.28.15",
    "typedoc-plugin-markdown": "4.9.0",
    "typescript": "^5.8.2",
    "vite": "^6.2.2",
    "vite-bundle-analyzer": "^1.3.2",
    "vite-plugin-dts": "^4.5.3",
    "vitest": "^4.0.16",
    "wait-on": "^9.0.3"
  },
  "dependencies": {
    "@vitest/browser-playwright": "^4.0.16",
    "canvas": "3.2.0",
    "eventemitter3": "5.0.1",
    "node": "^24.12.0",
    "qr-code-styling": "1.9.2",
    "socket.io-client": "4.8.3",
    "tweetnacl": "^1.0.3",
    "unist": "^0.0.1",
    "uuid": "^13.0.0"
  },
  "release": {
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/changelog",
      "@semantic-release/npm",
      [
        "@semantic-release/git",
        {
          "assets": [
            "CHANGELOG.md",
            "package.json"
          ],
          "message": "chore(release): [skip ci] Liquid Client \n\n${nextRelease.notes}"
        }
      ],
      [
        "@semantic-release/github",
        {
          "successComment": false
        }
      ]
    ],
    "branches": [
      "release/*",
      {
        "name": "main",
        "prerelease": "canary"
      }
    ]
  }
}
