{
  "name": "@algorandfoundation/liquid-client",
  "version": "1.0.0-canary.3",
  "description": "Connect to a Liquid Auth service",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/algorandfoundation/liquid-auth-js.git"
  },
  "bugs": {
    "url": "https://github.com/algorandfoundation/liquid-auth-js/issues"
  },
  "homepage": "https://github.com/algorandfoundation/liquid-auth-js#readme",
  "license": "Apache-2.0",
  "author": "Algorand Foundation",
  "type": "module",
  "main": "./lib/index.js",
  "browser": "./liquid-client.esm.js",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "default": "./lib/index.js"
    },
    "./attestation": {
      "types": "./lib/attestation.d.ts",
      "default": "./lib/attestation.js"
    },
    "./assertion": {
      "types": "./lib/assertion.d.ts",
      "default": "./lib/assertion.js"
    },
    "./assertion/fetch": {
      "types": "./lib/assertion.fetch.d.ts",
      "default": "./lib/assertion.fetch.js"
    },
    "./signal": {
      "types": "./lib/signal.d.ts",
      "default": "./lib/signal.js"
    },
    "./errors": {
      "types": "./lib/errors.d.ts",
      "default": "./lib/errors.js"
    },
    "./encoding": {
      "types": "./lib/encoding.d.ts",
      "default": "./lib/encoding.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "dev": "wait-on -t 3s http://localhost:3000/auth/session && vite",
    "build": "vite build",
    "build:docs": "typedoc --plugin typedoc-plugin-markdown --out docs src src/client",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "bench": "vitest bench",
    "test": "vitest",
    "test:browser": "vitest --browser.headless",
    "test:cov": "vitest run --coverage",
    "typedoc": "typedoc",
    "typedoc:watch": "typedoc --watch",
    "typedoc:serve": "nodemon --watch docs --exec \"http-server ./docs\"",
    "typedoc-dev": "concurrently \"npm:typedoc:*\"",
    "release": "semantic-release"
  },
  "dependencies": {
    "@algorandfoundation/algokit-utils": "^10.0.0-alpha.40",
    "eventemitter3": "^5.0.1",
    "qr-code-styling": "^1.9.2",
    "socket.io-client": "^4.7.5",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@codecov/vite-plugin": "^1.9.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^12.0.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^10.0.3",
    "@semantic-release/npm": "^12.0.0",
    "@semantic-release/release-notes-generator": "^13.0.0",
    "@simplewebauthn/browser": "^13.2.2",
    "@types/qrcode": "^1.5.5",
    "@types/uuid": "^10.0.0",
    "@vitest/browser": "^3.0.8",
    "@vitest/coverage-v8": "^3.0.8",
    "concurrently": "^9.1.2",
    "glob": "^11.0.1",
    "http-server": "^14.1.1",
    "nodemon": "^3.1.9",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "playwright": "^1.51.0",
    "semantic-release": "^23.0.8",
    "socket.io-mock-ts": "^1.0.2",
    "typedoc": "^0.28.17",
    "typedoc-plugin-markdown": "^4.10.0",
    "typescript": "^5.9.3",
    "vite": "^6.2.2",
    "vite-bundle-analyzer": "^0.18.0",
    "vite-plugin-dts": "^4.5.3",
    "vitest": "^3.0.8",
    "wait-on": "^8.0.3"
  },
  "release": {
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/changelog",
      "@semantic-release/npm",
      [
        "@semantic-release/git",
        {
          "assets": [
            "CHANGELOG.md",
            "package.json"
          ],
          "message": "chore(release): [skip ci] Liquid Client \n\n${nextRelease.notes}"
        }
      ],
      [
        "@semantic-release/github",
        {
          "successComment": false
        }
      ]
    ],
    "branches": [
      "release/*",
      {
        "name": "main",
        "prerelease": "canary"
      }
    ]
  }
}
